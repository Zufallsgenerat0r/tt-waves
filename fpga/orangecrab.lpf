# OrangeCrab r0.2.1 (ECP5-85F) pin constraints
# Pin mapping matches tt08-vga-donut working project.

# 48 MHz oscillator
LOCATE COMP "clk48" SITE "A9";
IOBUF PORT "clk48" IO_TYPE=LVCMOS33;
FREQUENCY PORT "clk48" 48.0 MHZ;
FREQUENCY NET "clk_vga" 25.6 MHZ;

# User button
LOCATE COMP "usr_btn" SITE "J17";
IOBUF PORT "usr_btn" IO_TYPE=SSTL135_I;

# RGB LED (active low)
LOCATE COMP "led_r" SITE "K4";
LOCATE COMP "led_g" SITE "M3";
LOCATE COMP "led_b" SITE "J3";
IOBUF PORT "led_r" IO_TYPE=LVCMOS33;
IOBUF PORT "led_g" IO_TYPE=LVCMOS33;
IOBUF PORT "led_b" IO_TYPE=LVCMOS33;

# VGA PMOD — matching tt08-vga-donut pin assignment
# TinyVGA Pmod top row (pins 1-4):
#   pin 1 = R1    -> gpio_a2 (N4)
#   pin 2 = G1    -> gpio_a1 (N3)
#   pin 3 = B1    -> gpio_a0 (L4)
#   pin 4 = VS    -> gpio_0  (N17)
# TinyVGA Pmod bottom row (pins 7-10):
#   pin 7 = R0    -> gpio_a5 (T17)
#   pin 8 = G0    -> gpio_a4 (G4)
#   pin 9 = B0    -> gpio_a3 (H4)
#   pin 10 = HS   -> gpio_1  (M18)

# uo_out = {HSYNC, B0, G0, R0, VSYNC, B1, G1, R1}
#            [7]   [6] [5] [4]  [3]   [2] [1] [0]
LOCATE COMP "pmod[0]" SITE "N4";
LOCATE COMP "pmod[1]" SITE "N3";
LOCATE COMP "pmod[2]" SITE "L4";
LOCATE COMP "pmod[3]" SITE "N17";
LOCATE COMP "pmod[4]" SITE "T17";
LOCATE COMP "pmod[5]" SITE "G4";
LOCATE COMP "pmod[6]" SITE "H4";
LOCATE COMP "pmod[7]" SITE "M18";
IOBUF PORT "pmod[0]" IO_TYPE=LVCMOS33;
IOBUF PORT "pmod[1]" IO_TYPE=LVCMOS33;
IOBUF PORT "pmod[2]" IO_TYPE=LVCMOS33;
IOBUF PORT "pmod[3]" IO_TYPE=LVCMOS33;
IOBUF PORT "pmod[4]" IO_TYPE=LVCMOS33;
IOBUF PORT "pmod[5]" IO_TYPE=LVCMOS33;
IOBUF PORT "pmod[6]" IO_TYPE=LVCMOS33;
IOBUF PORT "pmod[7]" IO_TYPE=LVCMOS33;

# Audio output: 1-bit sigma-delta on OrangeCrab r0.2.1 feather pin A5 (FPGA site A11).
# Solder an RC low-pass (or just a 1k resistor + audio cable) from this pin
# to an amp/speaker.
LOCATE COMP "audio" SITE "A11";
IOBUF PORT "audio" IO_TYPE=LVCMOS33;
